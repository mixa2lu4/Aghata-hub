local function ActivateHitbox()
    -- Remove hitboxes antigas
    for player, hitbox in pairs(hitboxConnections) do
        pcall(function() hitbox:Destroy() end)
    end
    hitboxConnections = {}
    
    Settings.HitboxEnabled = true
    
    -- Cria hitboxes para todos os jogadores (exceto você)
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local root = GetRoot(player.Character)
            if root then
                local hitbox = Instance.new("Part")
                hitbox.Size = Vector3.new(Settings.HitboxSize, Settings.HitboxSize, Settings.HitboxSize)
                hitbox.Transparency = 0.4
                hitbox.Color = PurpleColor
                hitbox.Material = Enum.Material.Neon
                hitbox.Anchored = false
                hitbox.CanCollide = false
                
                local weld = Instance.new("WeldConstraint")
                weld.Part0 = hitbox
                weld.Part1 = root
                weld.Parent = hitbox
                hitbox.Parent = workspace
                
                hitboxConnections[player] = hitbox
            end
        end
    end
end

local function DeactivateHitbox()
    Settings.HitboxEnabled = false
    for player, hitbox in pairs(hitboxConnections) do
        pcall(function() hitbox:Destroy() end)
    end
    hitboxConnections = {}
end

local function ToggleHitbox()
    if Settings.HitboxEnabled then
        DeactivateHitbox()
        infoLabel.Text = "❌ Hitbox DESATIVADA"
        buttonsList.HITBOX.BackgroundColor3 = DarkPurple
    else
        -- Mostra o dialog para escolher o tamanho
        ShowHitboxSizeDialog()
    end
end

-- ========== AURA ROXA ==========
local function ApplyAuraToPlayer(player)
    if not player or player == LocalPlayer then return end
    
    local character = player.Character
    if not character then return end
    
    if auraConnections[player] then
        for _, part in pairs(auraConnections[player]) do
            pcall(function() part:Destroy() end)
        end
        auraConnections[player] = nil
    end
    
    local auraPartsList = {}
    
    local function createAuraPart(parent, size)
        local part = Instance.new("Part")
        part.Size = size
        part.Shape = Enum.PartType.Ball
        part.Color = NeonRoxo
        part.Material = Enum.Material.Neon
        part.Transparency = 0.6
        part.Anchored = false
        part.CanCollide = false
        part.Parent = parent
        
        local weld = Instance.new("WeldConstraint")
        weld.Part0 = part
        weld.Part1 = parent
        weld.Parent = part
        
        local tweenInfo = TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
        local tween = TweenService:Create(part, tweenInfo, {Transparency = 0.3})
        tween:Play()
        
        table.insert(auraPartsList, part)
        return part
    end
    
    local root = GetRoot(character)
    if root then
        createAuraPart(root, Vector3.new(4, 1.5, 4))
        local head = character:FindFirstChild("Head")
        if head then
            createAuraPart(head, Vector3.new(3, 1, 3))
        end
    end
    
    auraConnections[player] = auraPartsList
end

local function ToggleAura()
    Settings.AuraEnabled = not Settings.AuraEnabled
    
    if Settings.AuraEnabled then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                ApplyAuraToPlayer(player)
            end
        end
        infoLabel.Text = "✨ Aura Roxa ATIVADA em todos"
        buttonsList.AURA.BackgroundColor3 = LightPurple
    else
        for player, parts in pairs(auraConnections) do
            for _, part in pairs(parts) do
                pcall(function() part:Destroy() end)
            end
        end
        auraConnections = {}
        infoLabel.Text = "✨ Aura Roxa DESATIVADA"
        buttonsList.AURA.BackgroundColor3 = DarkPurple
    end
    task.wait(1.5)
    infoLabel.Text = "✅ Pronto"
end

-- ========== TELEPORT, PULL, VISION ==========
local function TeleportToPlayer(player)
    if not player or not player.Character then return "❌ Jogador inválido" end
    
    local targetRoot = GetRoot(player.Character)
    local myRoot = GetRoot(LocalPlayer.Character)
    
    if targetRoot and myRoot then
        myRoot.CFrame = targetRoot.CFrame + Vector3.new(0, 3, 0)
        return "✅ Teleportado para " .. player.Name
    end
    return "❌ Falha"
end

local function PullPlayer(player)
    if not player or not player.Character then return "❌ Jogador inválido" end
    
    local targetRoot = GetRoot(player.Character)
    local myRoot = GetRoot(LocalPlayer.Character)
    
    if targetRoot and myRoot then
        for _, part in pairs(player.Character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
        
        targetRoot.CFrame = myRoot.CFrame + myRoot.CFrame.LookVector * 2
        
        task.wait(0.5)
        for _, part in pairs(player.Character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
        return "✨ " .. player.Name .. " puxado!"
    end
    return "❌ Falha"
end

local function ViewPlayer(player)
    if not player or not player.Character then return "❌ Jogador inválido" end
    
    local humanoid = GetHumanoid(player.Character)
    if not humanoid or humanoid.Health <= 0 then return "❌ Jogador morto" end
    
    if currentEffect then
        for _, effect in pairs(currentEffect) do
            pcall(function() effect:Destroy() end)
        end
    end
    
    local bloom = Instance.new("BloomEffect")
    bloom.Intensity = 0.25
    bloom.Size = 12
    bloom.Parent = Lighting
    
    local colorCorrection = Instance.new("ColorCorrectionEffect")
    colorCorrection.TintColor = PurpleColor
    colorCorrection.Contrast = 0.08
    colorCorrection.Parent = Lighting
    
    currentEffect = {bloom, colorCorrection}
    Camera.CameraSubject = humanoid
    
    if currentVisionConnection then
        currentVisionConnection:Disconnect()
    end
    
    currentVisionConnection = RunService.RenderStepped:Connect(function()
        if not player.Character or not player.Character.Parent then
            for _, effect in pairs(currentEffect or {}) do
                pcall(function() effect:Destroy() end)
            end
            currentEffect = nil
            Camera.CameraSubject = LocalPlayer.Character
            currentVisionConnection:Disconnect()
            currentVisionConnection = nil
        end
    end)
    
    return "👁️ Vendo: " .. player.Name
end

