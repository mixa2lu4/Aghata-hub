local function ToggleNoclip()
    Settings.NoclipEnabled = not Settings.NoclipEnabled
    
    if Settings.NoclipEnabled then
        if noclipConnection then noclipConnection:Disconnect() end
        noclipConnection = RunService.Stepped:Connect(function()
            local character = LocalPlayer.Character
            if character then
                for _, part in pairs(character:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end
        end)
        infoLabel.Text = "✅ NoClip ATIVADO"
        buttonsList.NOCLIP.BackgroundColor3 = LightPurple
    else
        if noclipConnection then
            noclipConnection:Disconnect()
            noclipConnection = nil
        end
        local character = LocalPlayer.Character
        if character then
            for _, part in pairs(character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = true
                end
            end
        end
        infoLabel.Text = "❌ NoClip DESATIVADO"
        buttonsList.NOCLIP.BackgroundColor3 = DarkPurple
    end
    task.wait(1.2)
    infoLabel.Text = "✅ Pronto"
end

local function CloneCharacter(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return "❌ Jogador inválido" end
    
    local myCharacter = LocalPlayer.Character
    if not myCharacter then return "❌ Sem personagem" end
    
    if #originalParts == 0 then
        for _, child in pairs(myCharacter:GetChildren()) do
            if child:IsA("BasePart") or child:IsA("Accessory") or child:IsA("Shirt") or child:IsA("Pants") then
                table.insert(originalParts, {Data = child:Clone()})
            end
        end
    end
    
    for _, part in pairs(clonedParts) do
        pcall(function() part:Destroy() end)
    end
    clonedParts = {}
    
    local targetChar = targetPlayer.Character
    local myHumanoid = GetHumanoid(myCharacter)
    local targetHumanoid = GetHumanoid(targetChar)
    
    for _, clothing in pairs(targetChar:GetChildren()) do
        if clothing:IsA("Shirt") or clothing:IsA("Pants") or clothing:IsA("ShirtGraphic") then
            local newClothing = clothing:Clone()
            newClothing.Parent = myCharacter
            table.insert(clonedParts, newClothing)
        end
    end
    
    for _, accessory in pairs(targetChar:GetChildren()) do
        if accessory:IsA("Accessory") then
            local newAcc = accessory:Clone()
            newAcc.Parent = myCharacter
            table.insert(clonedParts, newAcc)
        end
    end
    
    if targetHumanoid and myHumanoid then
        myHumanoid.HeadColor = targetHumanoid.HeadColor
        myHumanoid.TorsoColor = targetHumanoid.TorsoColor
        myHumanoid.LeftArmColor = targetHumanoid.LeftArmColor
        myHumanoid.RightArmColor = targetHumanoid.RightArmColor
        myHumanoid.LeftLegColor = targetHumanoid.LeftLegColor
        myHumanoid.RightLegColor = targetHumanoid.RightLegColor
    end
    
    return "🎭 Clonado: " .. targetPlayer.Name
end

local function ResetCharacter()
    local myCharacter = LocalPlayer.Character
    if not myCharacter then return "❌ Sem personagem" end
    
    for _, part in pairs(clonedParts) do
        pcall(function() part:Destroy() end)
    end
    clonedParts = {}
    
    for _, partData in pairs(originalParts) do
        pcall(function()
            local newPart = partData.Data:Clone()
            newPart.Parent = myCharacter
        end)
    end
    
    local humanoid = GetHumanoid(myCharacter)
    if humanoid then
        humanoid.HeadColor = Color3.fromRGB(255,255,255)
        humanoid.TorsoColor = Color3.fromRGB(255,255,255)
        humanoid.LeftArmColor = Color3.fromRGB(255,255,255)
        humanoid.RightArmColor = Color3.fromRGB(255,255,255)
        humanoid.LeftLegColor = Color3.fromRGB(255,255,255)
        humanoid.RightLegColor = Color3.fromRGB(255,255,255)
    end
    
    return "✅ Resetado"
end

local function ToggleInvisibility()
    Settings.Invisible = not Settings.Invisible
    local character = LocalPlayer.Character
    if not character then return "❌ Sem personagem" end
    
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") or part:IsA("MeshPart") then
            part.Transparency = Settings.Invisible and 1 or 0
        end
    end
    
    if Settings.Invisible then
        infoLabel.Text = "✅ Invisível"
        buttonsList.INVIS.BackgroundColor3 = LightPurple
    else
        infoLabel.Text = "❌ Visível"
        buttonsList.INVIS.BackgroundColor3 = DarkPurple
    end
    task.wait(1)
    infoLabel.Text = "✅ Pronto"
end

local function ToggleSuperJump()
    Settings.SuperJump = not Settings.SuperJump
    local character = LocalPlayer.Character
    local humanoid = character and GetHumanoid(character)
    
    if humanoid then
        if Settings.SuperJump then
            Settings.OriginalJumpPower = humanoid.JumpPower
            Settings.OriginalGravity = Workspace.Gravity
            humanoid.JumpPower = 120
            Workspace.Gravity = 30
            infoLabel.Text = "✅ Super Pulo ON"
            buttonsList.SUPERJUMP.BackgroundColor3 = LightPurple
        else
            humanoid.JumpPower = Settings.OriginalJumpPower or 50
            Workspace.Gravity = Settings.OriginalGravity or 196.2
            infoLabel.Text = "❌ Super Pulo OFF"
            buttonsList.SUPERJUMP.BackgroundColor3 = DarkPurple
        end
    end
    task.wait(1)
    infoLabel.Text = "✅ Pronto"
end

-- ========== TELECINESIA MOBILE ==========
local function TelekinesisMobile(player)
    if Settings.TelekinesisActive then
        if Settings.TelekinesisTarget and Settings.TelekinesisTarget.Character then
            local humanoid = GetHumanoid(Settings.TelekinesisTarget.Character)
            if humanoid then
                humanoid.PlatformStand = false
            end
        end
        Settings.TelekinesisActive = false
        Settings.TelekinesisTarget = nil
        infoLabel.Text = "❌ Telecinesia DESATIVADA"
        buttonsList.TELEK.BackgroundColor3 = DarkPurple
    elseif player then
        local character = player.Character
        if not character then
            infoLabel.Text = "❌ Jogador sem personagem"
            return
        end
        local humanoid = GetHumanoid(character)
        if humanoid then
            Settings.TelekinesisActive = true
            Settings.TelekinesisTarget = player
            humanoid.PlatformStand = true
            infoLabel.Text = "🌀 " .. player.Name .. " levitando!"
            buttonsList.TELEK.BackgroundColor3 = LightPurple
        end
    end
    task.wait(1.5)
    if not Settings.TelekinesisActive then
        infoLabel.Text = "✅ Pronto"
    end
end

-- Loop da telecinesia
RunService.Heartbeat:Connect(function()
    if Settings.TelekinesisActive and Settings.TelekinesisTarget then
        local character = Settings.TelekinesisTarget.Character
        if character then
            local root = GetRoot(character)
            local myRoot = GetRoot(LocalPlayer.Character)
            if root and myRoot then
                -- O jogador levita na sua frente
                local targetPos = myRoot.Position + myRoot.CFrame.LookVector * 3 + Vector3.new(0, 3, 0)
                root.Velocity = (targetPos - root.Position) * 5
            end
        else
            Settings.TelekinesisActive = false
            Settings.TelekinesisTarget = nil
            buttonsList.TELEK.BackgroundColor3 = DarkPurple
        end
    end
end)

